#!/usr/bin/env bash
set -euo pipefail

APP=/opt/openvpn-web
cd "$APP"
exec "$APP/.venv/bin/python" -m app.server_draft_worker \
  --queue-dir /var/lib/openvpn-web/server-drafts/queue \
  --results-dir /var/lib/openvpn-web/server-drafts/results \
  --private-dir /var/lib/openvpn-web/server-drafts/private \
  "$@"
