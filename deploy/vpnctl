def client_paths(client: str) -> Dict[str, Path]:
    out = CFG.path("OUT_DIR")
    share = CFG.path("SHARE_OUT_DIR")
    return {
        "crt": CFG.path("PKI_DIR") / "issued" / f"{client}.crt",
        "key": CFG.path("PKI_DIR") / "private" / f"{client}.key",
        "req": CFG.path("PKI_DIR") / "reqs" / f"{client}.req",
        "tlscrypt": out / f"{client}.tls-crypt-v2.key",
        "ovpn": out / f"{client}.ovpn",
        "bat": out / f"{client}-install-hosts-as-admin.bat",
        "ccd": CFG.path("CCD_DIR") / client,
        "share_ovpn": share / f"{client}.ovpn",
        "share_bat": share / f"{client}-install-hosts-as-admin.bat",
    }


def cert_status(client: str) -> str:
    index = CFG.path("PKI_DIR") / "index.txt"
    if not index.exists():
        return "unknown"
    # Easy-RSA index format: V/R/E\t...\t/CN=name
    for line in index.read_text(encoding="utf-8", errors="replace").splitlines():
        if f"/CN={client}" in line or line.rstrip().endswith(f"CN={client}") or f"\t{client}" in line:
            first = line.split("\t", 1)[0]
            if first == "V":
                return "valid"
            if first == "R":
                return "revoked"
            if first == "E":
                return "expired"
    return "missing"


def extract_cert(path: Path) -> str:
    text = path.read_text(encoding="utf-8", errors="replace")
    m = re.search(r"-----BEGIN CERTIFICATE-----.*?-----END CERTIFICATE-----", text, re.S)
    if not m:
        raise SystemExit(f"Ошибка: не удалось извлечь сертификат из {path}")
    return m.group(0).strip() + "\n"


def build_ovpn(client: str) -> str:
    paths = client_paths(client)
    for req in [CFG.path("PKI_DIR") / "ca.crt", paths["crt"], paths["key"], paths["tlscrypt"]]:
        if not req.exists():
            raise SystemExit(f"Ошибка: не найден файл для .ovpn: {req}")
    parts = [
        "client",
        f"proto {CFG.PROTO}",
        "explicit-exit-notify",
        f"remote {CFG.REMOTE_HOST} {CFG.REMOTE_PORT}",
        "dev tun",
        "resolv-retry infinite",
        "nobind",
        "persist-key",
        "persist-tun",
        "remote-cert-tls server",
        f"verify-x509-name {CFG.SERVER_VERIFY_NAME} name",
        "auth SHA256",
        "auth-nocache",
        "cipher AES-128-GCM",
        "ignore-unknown-option data-ciphers",
        "data-ciphers AES-128-GCM",
        "ncp-ciphers AES-128-GCM",
        "tls-client",
        "tls-version-min 1.2",
        "tls-cipher TLS-ECDHE-ECDSA-WITH-AES-128-GCM-SHA256",
        "tls-ciphersuites TLS_AES_256_GCM_SHA384:TLS_AES_128_GCM_SHA256:TLS_CHACHA20_POLY1305_SHA256",
        "verb 3",
        "",
        "<ca>",
        (CFG.path("PKI_DIR") / "ca.crt").read_text(encoding="utf-8", errors="replace").strip(),
        "</ca>",
        "",
        "<cert>",
        extract_cert(paths["crt"]).strip(),
        "</cert>",
        "",
        "<key>",
        paths["key"].read_text(encoding="utf-8", errors="replace").strip(),
        "</key>",
        "",
        "<tls-crypt-v2>",
        paths["tlscrypt"].read_text(encoding="utf-8", errors="replace").strip(),
        "</tls-crypt-v2>",
        "",
    ]
    return "\n".join(parts)


