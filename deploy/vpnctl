def check_vpn_ip_collision(client: str, vpn_ip: str, client_type: str = "user") -> None:
    if not vpn_ip:
        return
    validate_vpn_ip(vpn_ip, client_type)
    ccd = CFG.path("CCD_DIR")
    if not ccd.exists():
        return
    needle = f"ifconfig-push {vpn_ip} "
    for path in ccd.iterdir():
        if not path.is_file() or path.name == client or ".backup." in path.name:
            continue
        try:
            if needle in path.read_text(encoding="utf-8", errors="replace"):
                raise SystemExit(f"Ошибка: VPN IP {vpn_ip} уже используется в CCD-файле {path}")
        except UnicodeDecodeError:
            continue


def router_instructions(client_type: str, remote_lan_cidr: str = "") -> List[str]:
    client_type = normalize_client_type(client_type)
    if client_type == "router_nat":
        return [
            "Import OVPN profile into router.",
            "Enable NAT/MASQUERADE from router LAN to OpenVPN tunnel.",
            "Route central and ViPNet target networks through OpenVPN.",
            "OpenVPN server will see only router VPN IP.",
        ]
    if client_type == "router_site_to_site":
        return [
            "Import OVPN profile into router.",
            "Disable NAT/MASQUERADE from remote LAN to OpenVPN tunnel.",
            f"Ensure remote LAN is exactly: {remote_lan_cidr}.",
            f"OpenVPN CCD contains iroute for {remote_lan_cidr}.",
            f"OpenVPN server.conf contains route for {remote_lan_cidr}.",
            f"MikroTik must route {remote_lan_cidr} to 192.168.100.30 and include it in vipnet2corp.",
            f"ViPNet Coordinator tunnel ranges must include {remote_lan_cidr}.",
        ]
    return []


def generate_client(
    client: str,
    profile: str,
    vpn_ip: str = "",
    dry_run: bool = False,
    comment: str = "",
    client_type: str = "user",
    remote_lan_cidr: str = "",
    create_server_route: bool = False,
) -> Dict[str, Any]:
    validate_client(client)
    validate_profile(profile)
    client_type = normalize_client_type(client_type)
    remote_lan_cidr = validate_client_network_plan(client_type, vpn_ip, remote_lan_cidr)
    ensure_dirs()
    paths = client_paths(client)
    check_vpn_ip_collision(client, vpn_ip, client_type)
    ccd = ccd_content(profile, vpn_ip, client_type=client_type, remote_lan_cidr=remote_lan_cidr)
    planned_server_routes = [server_route_line(remote_lan_cidr)] if client_type == "router_site_to_site" and create_server_route else []
    result: Dict[str, Any] = {
        "status": "preview" if dry_run else "ok",
        "client": client,
        "profile": profile,
        "access_profile": profile,
        "client_type": client_type,
        "remote_lan_cidr": remote_lan_cidr or None,
        "create_server_route": bool(create_server_route),
        "vpn_ip": vpn_ip or None,
        "ccd_path": str(paths["ccd"]),
        "ovpn_path": str(paths["ovpn"]),
        "tlscrypt_path": str(paths["tlscrypt"]),
        "bat_path": str(paths["bat"]) if profile.endswith("_hosts") else None,
        "share_ovpn_path": str(paths["share_ovpn"]),
        "cert_exists_before": paths["crt"].exists(),
        "key_exists_before": paths["key"].exists(),
        "tlscrypt_exists_before": paths["tlscrypt"].exists(),
        "ccd_exists_before": paths["ccd"].exists(),
        "ovpn_exists_before": paths["ovpn"].exists(),
        "ccd_preview": ccd.splitlines(),
        "server_routes_preview": planned_server_routes,
        "router_instructions": router_instructions(client_type, remote_lan_cidr),
        "actions": [],
    }

    if dry_run:
        result["actions"] = [
            "validate profile and client name",
            "issue certificate if missing",
            "generate tls-crypt-v2 if missing",
            "backup existing CCD/OVPN if present",
            "write CCD",
            "write OVPN",
            "write hosts BAT if profile ends with _hosts",
            "add site route managed block if requested",
            "copy OVPN/BAT to share if mounted",
            "write/update SQLite registry",
        ]
        return result

    if not CFG.path("EASYRSA_DIR").is_dir():
        raise SystemExit(f"Ошибка: не найден Easy-RSA: {CFG.EASYRSA_DIR}")
    if not (CFG.path("OPENVPN_DIR") / "tls-crypt-v2.key").exists():
        raise SystemExit(f"Ошибка: не найден {CFG.OPENVPN_DIR}/tls-crypt-v2.key")

    if not paths["crt"].exists() or not paths["key"].exists():
        proc = run(["./easyrsa", "build-client-full", client, "nopass"], cwd=CFG.path("EASYRSA_DIR"), env={"EASYRSA_BATCH": "1"})
        result["actions"].append("certificate_issued")
        if proc.stdout:
            result["easyrsa_stdout"] = proc.stdout[-4000:]
        if proc.stderr:
            result["easyrsa_stderr"] = proc.stderr[-4000:]
    else:
        result["actions"].append("certificate_reused")

    if not paths["tlscrypt"].exists():
        run(["openvpn", "--tls-crypt-v2", str(CFG.path("OPENVPN_DIR") / "tls-crypt-v2.key"), "--genkey", "tls-crypt-v2-client", str(paths["tlscrypt"])])
        os.chmod(paths["tlscrypt"], 0o600)
        result["actions"].append("tlscrypt_generated")
    else:
        result["actions"].append("tlscrypt_reused")

    backups = []
    for p in [paths["ccd"], paths["ovpn"], paths["bat"]]:
        b = backup_file(p)
        if b:
            backups.append(str(b))
    result["backups"] = backups

    write_ccd_file(paths["ccd"], ccd)
    result["actions"].append("ccd_written")
    if planned_server_routes:
        route_result = add_site_route(remote_lan_cidr, client=client, restart=False)
        result["site_route"] = route_result
        result["actions"].append("site_route_written")

    ovpn_content = build_ovpn(client)
    atomic_write(paths["ovpn"], ovpn_content, 0o600)
    make_download_file_readable(paths["ovpn"])
    result["actions"].append("ovpn_written")

    if profile.endswith("_hosts"):
        atomic_write(paths["bat"], build_hosts_bat(), 0o600)
        make_download_file_readable(paths["bat"])
        result["actions"].append("bat_written")
    elif paths["bat"].exists():
        # Do not delete BAT automatically on profile change; archive it for safety.
        archive_one(client, paths["bat"], purge=False)
        result["actions"].append("old_bat_archived")

    # Preserve old behavior: copy to share if mounted.
    share = CFG.path("SHARE_OUT_DIR")
    if is_mountpoint(Path("/mnt/antares_soft")) and share.is_dir():
        shutil.copy2(paths["ovpn"], paths["share_ovpn"])
        result["actions"].append("ovpn_copied_to_share")
        if profile.endswith("_hosts") and paths["bat"].exists():
            shutil.copy2(paths["bat"], paths["share_bat"])
            result["actions"].append("bat_copied_to_share")
    else:
        result["share_warning"] = f"Сетевая шара не смонтирована или папка недоступна: {share}"

    row = {
        "name": client,
        "profile": profile,
        "detected_profile": infer_profile(client, paths["ccd"], paths["bat"]),
        "vpn_ip": vpn_ip or parse_ccd(paths["ccd"]).get("vpn_ip"),
        "client_type": client_type,
        "remote_lan_cidr": remote_lan_cidr or None,
        "status": "active" if cert_status(client) != "revoked" else "revoked",
        "updated_at": now_iso(),
        "ovpn_path": str(paths["ovpn"]),
        "ccd_path": str(paths["ccd"]),
        "tlscrypt_path": str(paths["tlscrypt"]),
        "bat_path": str(paths["bat"]) if paths["bat"].exists() else None,
        "share_ovpn_path": str(paths["share_ovpn"]) if paths["share_ovpn"].exists() else None,
        "comment": comment,
        "cert_exists": int(paths["crt"].exists()),
        "key_exists": int(paths["key"].exists()),
        "ccd_exists": int(paths["ccd"].exists()),
        "ovpn_exists": int(paths["ovpn"].exists()),
    }
    upsert_client(row)
    record_operation("generate", client, "ok", f"profile={profile} vpn_ip={vpn_ip or '-'}")
    return result


def is_mountpoint(path: Path) -> bool:
    try:
        return path.is_dir() and os.path.ismount(str(path))
    except OSError:
        return False

