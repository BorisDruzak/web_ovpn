def scan_existing() -> List[Dict[str, Any]]:
    ensure_dirs()
    names = set()
    for d in [CFG.path("CCD_DIR"), CFG.path("OUT_DIR")]:
        if not d.exists():
            continue
        for p in d.iterdir():
            if not p.is_file():
                continue
            name = None
            if d == CFG.path("CCD_DIR"):
                if ".backup." in p.name or p.name.startswith("."):
                    continue
                name = p.name
            elif p.name.endswith(".ovpn"):
                name = p.stem
            elif p.name.endswith(".tls-crypt-v2.key"):
                name = p.name[: -len(".tls-crypt-v2.key")]
            elif p.name.endswith("-install-hosts-as-admin.bat"):
                name = p.name[: -len("-install-hosts-as-admin.bat")]
            if name and CLIENT_RE.match(name):
                names.add(name)
    rows: List[Dict[str, Any]] = []
    for name in sorted(names):
        paths = client_paths(name)
        detected = infer_profile(name, paths["ccd"], paths["bat"]) if paths["ccd"].exists() else "unknown"
        parsed = parse_ccd(paths["ccd"])
        client_type = infer_client_type_from_ccd(parsed)
        remote_lan = sorted(parsed.get("iroutes", []))[0] if parsed.get("iroutes") else None
        status = cert_status(name)
        if status == "valid":
            reg_status = "active"
        elif status == "revoked":
            reg_status = "revoked"
        else:
            reg_status = status
        row = {
            "name": name,
            "profile": detected if detected in PROFILE_DESCRIPTIONS else None,
            "detected_profile": detected,
            "vpn_ip": parsed.get("vpn_ip"),
            "client_type": client_type,
            "remote_lan_cidr": remote_lan,
            "status": reg_status,
            "updated_at": now_iso(),
            "ovpn_path": str(paths["ovpn"]),
            "ccd_path": str(paths["ccd"]),
            "tlscrypt_path": str(paths["tlscrypt"]),
            "bat_path": str(paths["bat"]) if paths["bat"].exists() else None,
            "share_ovpn_path": str(paths["share_ovpn"]) if paths["share_ovpn"].exists() else None,
            "comment": "imported-from-files",
            "cert_exists": int(paths["crt"].exists()),
            "key_exists": int(paths["key"].exists()),
            "ccd_exists": int(paths["ccd"].exists()),
            "ovpn_exists": int(paths["ovpn"].exists()),
        }
        rows.append(row)
    return rows


def sync_registry() -> Dict[str, Any]:
    rows = scan_existing()
    for row in rows:
        upsert_client(row)
    record_operation("sync", None, "ok", f"count={len(rows)}")
    return {"status": "ok", "imported_or_updated": len(rows), "clients": rows}


