def main(argv: Optional[List[str]] = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        if args.cmd == "profiles":
            data = {"profiles": [{"name": k, "description": v} for k, v in PROFILE_DESCRIPTIONS.items()]}
            if args.json:
                emit(data, args)
            else:
                for item in data["profiles"]:
                    print(f"{item['name']:<24} {item['description']}")
            return 0

        if args.cmd in {"generate", "preview"}:
            dry = bool(getattr(args, "dry_run", False) or args.cmd == "preview")
            if dry:
                data = generate_client(
                    args.client,
                    args.profile,
                    args.vpn_ip,
                    dry_run=True,
                    comment=getattr(args, "comment", ""),
                    client_type=args.client_type,
                    remote_lan_cidr=args.remote_lan,
                    create_server_route=args.create_server_route,
                )
            else:
                with lock_exclusive():
                    data = generate_client(
                        args.client,
                        args.profile,
                        args.vpn_ip,
                        dry_run=False,
                        comment=getattr(args, "comment", ""),
                        client_type=args.client_type,
                        remote_lan_cidr=args.remote_lan,
                        create_server_route=args.create_server_route,
                    )
            if args.json:
                emit(data, args)
            else:
                print(f"status: {data['status']}")
                print(f"client: {data['client']}")
                print(f"profile: {data['profile']}")
                if data.get("vpn_ip"):
                    print(f"vpn_ip: {data['vpn_ip']}")
                print(f"CCD: {data['ccd_path']}")
                print(f"OVPN: {data['ovpn_path']}")
                if data.get("bat_path"):
                    print(f"BAT: {data['bat_path']}")
                if dry:
                    print("\nCCD preview:")
                    for line in data["ccd_preview"]:
                        print(line)
                if data.get("share_warning"):
                    print("warning:", data["share_warning"])
            return 0

        if args.cmd == "sync":
            with lock_exclusive():
                data = sync_registry()
            emit(data, args)
            return 0

        if args.cmd == "list":
            data = {"clients": list_clients()}
            if args.json:
                emit(data, args)
            else:
                print(f"{'client':<28} {'profile':<24} {'status':<10} {'vpn_ip':<14} {'connected':<9}")
                for r in data["clients"]:
                    print(f"{r['name']:<28} {(r.get('profile') or r.get('detected_profile') or '-'):<24} {r.get('status','-'):<10} {(r.get('vpn_ip') or '-'):<14} {str(r.get('connected')):<9}")
            return 0

        if args.cmd == "connected":
            data = connected_clients_result(source=args.source)
            if args.json:
                emit(data, args)
            else:
                if not data["connected"]:
                    print("Нет текущих подключений.")
                else:
                    print(f"{'client':<28} {'vpn_ip':<14} {'real_address':<28} {'rx':<12} {'tx':<12}")
                    for r in data["connected"]:
                        print(f"{r.get('common_name',''):<28} {r.get('virtual_address',''):<14} {r.get('real_address',''):<28} {str(r.get('bytes_received','')):<12} {str(r.get('bytes_sent','')):<12}")
            return 0

        if args.cmd == "inspect":
            data = inspect_client(args.client)
            emit(data, args)
            return 0

        if args.cmd == "config-view":
            data = view_client_config(args.client)
            emit(data, args)
            return 0

        if args.cmd == "ccd-update":
            with lock_exclusive():
                data = update_ccd(args.client, args.content, reason=args.reason)
            emit(data, args)
            return 0

        if args.cmd == "profile-apply":
            with lock_exclusive():
                data = apply_profile_to_client(args.client, args.profile, args.vpn_ip, reason=args.reason)
            emit(data, args)
            return 0

        if args.cmd == "ovpn-update":
            with lock_exclusive():
                data = update_ovpn(args.client, args.content, reason=args.reason)
            emit(data, args)
            return 0

        if args.cmd == "repair-artifacts":
            with lock_exclusive():
                data = repair_client_artifacts(args.client, reason=args.reason)
            emit(data, args)
            return 0

        if args.cmd == "client-networks-apply":
            with lock_exclusive():
                data = apply_networks_to_client(
                    args.client,
                    list(args.cidr),
                    vpn_ip=args.vpn_ip,
                    dns=args.dns,
                    reason=args.reason,
                )
            emit(data, args)
            return 0

        if args.cmd == "client-template-apply":
            with lock_exclusive():
                data = apply_network_template_to_client(args.client, args.template, args.vpn_ip, reason=args.reason)
            emit(data, args)
            return 0

        if args.cmd in {"reconnect-client", "reconnect"}:
            with lock_exclusive():
                data = reconnect_client(args.client, reason=args.reason)
            emit(data, args)
            return 0

        if args.cmd == "disable":
            with lock_exclusive():
                data = disable_or_delete(args.client, "disable", purge=False, reason=args.reason, kill_active=args.kill_active)
            emit(data, args)
            return 0

        if args.cmd == "delete":
            with lock_exclusive():
                data = disable_or_delete(args.client, "delete", purge=args.purge, reason=args.reason, kill_active=args.kill_active)
            emit(data, args)
            return 0

        if args.cmd == "logs":
            data = {"services": service_status(), "operations": operation_lines(args.lines), "journal": journal_lines(args.lines)}
            if args.json:
                emit(data, args)
            else:
                print("===== SERVICES =====")
                print_human(data["services"])
                print("===== OPERATIONS =====")
                print_human(data["operations"])
                print("===== OPENVPN JOURNAL =====")
                for line in data["journal"]:
                    print(line)
            return 0

        if args.cmd == "status":
            data = {"services": service_status(), "connected": connected_clients()}
            emit(data, args)
            return 0

        if args.cmd == "server-config":
            if args.server_config_cmd == "inspect":
                data = inspect_server_config()
            elif args.server_config_cmd == "apply":
                data = patch_server_config(
                    status_interval=args.status_interval,
                    status_version=args.status_version,
                    enable_management=args.enable_management,
                    management_socket=args.management_socket,
                    management_client_group=args.management_client_group,
                    management_log_cache=args.management_log_cache,
                    restart=args.restart,
                )
            elif args.server_config_cmd == "restart-openvpn":
                data = {"status": "ok", "restart": restart_openvpn_service()}
            elif args.server_config_cmd == "migrate-pool":
                data = migrate_server_pool(args.from_cidr, args.to_cidr, backup=args.backup, restart=args.restart)
            else:
                raise SystemExit("unknown server-config command")
            emit(data, args)
            return 0

        if args.cmd == "management":
            if args.management_cmd == "test":
                data = management_test()
            elif args.management_cmd == "status":
                data = management_status()
            elif args.management_cmd == "kill":
                data = management_kill_client(args.client)
            elif args.management_cmd == "parse-status-sample":
                data = {"status": "ok", "source": "sample", "clients": parse_management_status(args.content)}
            else:
                raise SystemExit("unknown management command")
            emit(data, args)
            return 0

        if args.cmd == "vipnet-nets":
            if args.vipnet_cmd == "list":
                data = {"vipnet_nets_file": CFG.VIPNET_NETS_FILE, "networks": read_vipnet_nets()}
            elif args.vipnet_cmd == "add":
                data = add_vipnet_net(args.cidr, restart_nat=args.restart_nat)
            elif args.vipnet_cmd == "remove":
                data = remove_vipnet_net(args.cidr, restart_nat=args.restart_nat)
            else:
                raise SystemExit("unknown vipnet-nets command")
            emit(data, args)
            return 0

        if args.cmd == "networks":
            if args.networks_cmd == "list":
                data = {
                    "networks_file": CFG.NETWORKS_DB,
                    "nat_file": CFG.VIPNET_NETS_FILE,
                    "networks": list_networks(),
                }
            elif args.networks_cmd in {"add", "update"}:
                data = add_or_update_network(
                    args.cidr,
                    tag=args.tag,
                    nat=args.nat,
                    comment=args.comment,
                    restart_nat=args.restart_nat,
                )
            elif args.networks_cmd == "remove":
                data = remove_network(args.cidr, restart_nat=args.restart_nat)
            else:
                raise SystemExit("unknown networks command")
            emit(data, args)
            return 0

        if args.cmd == "network-templates":
            if args.templates_cmd == "list":
                data = {
                    "templates_file": CFG.NETWORK_TEMPLATES_DB,
                    "templates": list_network_templates(),
                    "networks": list_networks(),
                }
            elif args.templates_cmd == "add":
                data = add_network_template(args.name, list(args.cidr), description=args.description, dns=args.dns)
            elif args.templates_cmd == "remove":
                data = remove_network_template(args.name)
            else:
                raise SystemExit("unknown network-templates command")
            emit(data, args)
            return 0

        if args.cmd == "nat-status":
            data = nat_status()
            emit(data, args)
            return 0

        if args.cmd == "nat":
            if args.nat_cmd == "disable-legacy":
                data = disable_legacy_nat()
            else:
                raise SystemExit("unknown nat command")
            emit(data, args)
            return 0

        if args.cmd == "site-routes":
            if args.site_routes_cmd == "list":
                data = {"status": "ok", "server_conf": CFG.SERVER_CONF, "site_routes": site_routes()}
            elif args.site_routes_cmd == "add":
                data = add_site_route(args.cidr, client=args.client, restart=args.restart)
            elif args.site_routes_cmd == "remove":
                data = remove_site_route(args.cidr, restart=args.restart)
            else:
                raise SystemExit("unknown site-routes command")
            emit(data, args)
            return 0

        if args.cmd == "validate-network-plan":
            data = validate_network_plan()
            emit(data, args)
            return 0

        parser.print_help()
        return 2
    except subprocess.CalledProcessError as e:
        msg = {
            "status": "error",
            "command": e.cmd,
            "returncode": e.returncode,
            "stdout": e.stdout,
            "stderr": e.stderr,
        }
        record_operation(args.cmd, getattr(args, "client", None), "error", e.stderr or str(e))
        if args.json:
            print(json.dumps(msg, ensure_ascii=False, indent=2), file=sys.stderr)
        else:
            print("Ошибка выполнения команды:", e.cmd, file=sys.stderr)
            if e.stdout:
                print(e.stdout, file=sys.stderr)
            if e.stderr:
                print(e.stderr, file=sys.stderr)
        return e.returncode or 1
    except SystemExit as e:
        # argparse also raises SystemExit; pass numeric codes through.
        if isinstance(e.code, int):
            raise
        record_operation(args.cmd, getattr(args, "client", None), "error", str(e.code))
        if args.json:
            print(json.dumps({"status": "error", "message": str(e.code)}, ensure_ascii=False, indent=2), file=sys.stderr)
        else:
            print(str(e.code), file=sys.stderr)
        return 1
    except Exception as e:
        record_operation(args.cmd, getattr(args, "client", None), "error", repr(e))
        if args.json:
            print(json.dumps({"status": "error", "message": repr(e)}, ensure_ascii=False, indent=2), file=sys.stderr)
        else:
            print(f"Ошибка: {e!r}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
