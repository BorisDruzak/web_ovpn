def now_iso() -> str:
    return dt.datetime.now(dt.timezone.utc).astimezone().isoformat(timespec="seconds")


def timestamp() -> str:
    return dt.datetime.now().strftime("%Y-%m-%d_%H-%M-%S")


def load_env_file(path: Path) -> Dict[str, str]:
    data: Dict[str, str] = {}
    if not path.exists():
        return data
    try:
        lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except PermissionError:
        return data
    for raw in lines:
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, val = line.split("=", 1)
        key = key.strip()
        val = val.strip().strip('"').strip("'")
        if key:
            data[key] = val
    return data


class Cfg:
    def __init__(self) -> None:
        cfg = dict(DEFAULTS)
        cfg.update(load_env_file(Path("/etc/openvpn/vpnctl.env")))
        for key in list(cfg.keys()):
            if key in os.environ:
                cfg[key] = os.environ[key]
        self.values = cfg

    def __getattr__(self, name: str) -> str:
        if name in self.values:
            return self.values[name]
        raise AttributeError(name)

    def path(self, name: str) -> Path:
        return Path(self.values[name])


CFG = Cfg()


def is_json_mode(args: argparse.Namespace) -> bool:
    return bool(getattr(args, "json", False))


def emit(data: Any, args: argparse.Namespace, human: Optional[str] = None) -> None:
    if is_json_mode(args):
        print(json.dumps(data, ensure_ascii=False, indent=2))
    else:
        if human is not None:
            print(human)
        else:
            print_human(data)


def print_human(data: Any) -> None:
    if isinstance(data, dict):
        for k, v in data.items():
            if isinstance(v, (dict, list)):
                print(f"{k}:")
                print_human(v)
            else:
                print(f"{k}: {v}")
    elif isinstance(data, list):
        for item in data:
            if isinstance(item, dict):
                print("- " + ", ".join(f"{k}={v}" for k, v in item.items()))
            else:
                print(f"- {item}")
    else:
        print(data)


def run(cmd: List[str], cwd: Optional[Path] = None, env: Optional[Dict[str, str]] = None, check: bool = True) -> subprocess.CompletedProcess:
    proc_env = os.environ.copy()
    if env:
        proc_env.update(env)
    return subprocess.run(
        cmd,
        cwd=str(cwd) if cwd else None,
        env=proc_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=check,
    )


def validate_client(name: str) -> None:
    if not name or not CLIENT_RE.match(name):
        raise SystemExit("Ошибка: имя клиента должно содержать только латиницу, цифры, точку, дефис или подчёркивание.")


def validate_profile(profile: str) -> None:
    if profile not in PROFILE_DESCRIPTIONS:
        raise SystemExit(f"Ошибка: неизвестный профиль: {profile}. Выполните: vpnctl profiles")


def cidr_list(value: str) -> List[str]:
    return [normalize_cidr(item.strip()) for item in (value or "").split(",") if item.strip()]


def tunnel_network() -> ipaddress.IPv4Network:
    return ipaddress.ip_network(CFG.OPENVPN_TUNNEL_CIDR or CFG.VPN_NETWORK, strict=False)


def legacy_networks() -> List[ipaddress.IPv4Network]:
    return [ipaddress.ip_network(cidr, strict=False) for cidr in cidr_list(CFG.OPENVPN_LEGACY_CIDRS)]


def ip_range_contains(start: str, end: str, addr: ipaddress.IPv4Address) -> bool:
    return ipaddress.ip_address(start) <= addr <= ipaddress.ip_address(end)


def normalize_client_type(client_type: str) -> str:
    value = (client_type or "user").strip()
    if value not in CLIENT_TYPES:
        raise SystemExit(f"Ошибка: неизвестный тип клиента: {value}")
    return value


def validate_vpn_ip(ip: str, client_type: str = "user") -> None:
    client_type = normalize_client_type(client_type)
    try:
        addr = ipaddress.ip_address(ip)
    except ValueError as e:
        raise SystemExit(f"Ошибка: неверный VPN IP: {ip}: {e}")
    if addr.version != 4:
        raise SystemExit("Ошибка: VPN IP должен быть IPv4.")
    net = tunnel_network()
    if addr not in net:
        raise SystemExit(f"Ошибка: VPN IP {ip} должен быть внутри {net}.")
    if str(addr) == CFG.OPENVPN_SERVER_TUNNEL_IP:
        raise SystemExit(f"Ошибка: {CFG.OPENVPN_SERVER_TUNNEL_IP} зарезервирован за OpenVPN-сервером.")
    if client_type == "user" and not ip_range_contains(CFG.OPENVPN_USER_POOL_START, CFG.OPENVPN_USER_POOL_END, addr):
        raise SystemExit(
            f"Ошибка: VPN IP пользователя должен быть в диапазоне {CFG.OPENVPN_USER_POOL_START}-{CFG.OPENVPN_USER_POOL_END}."
        )
    if client_type in {"router_nat", "router_site_to_site"} and not ip_range_contains(CFG.OPENVPN_ROUTER_POOL_START, CFG.OPENVPN_ROUTER_POOL_END, addr):
        raise SystemExit(
            f"Ошибка: VPN IP роутера должен быть в диапазоне {CFG.OPENVPN_ROUTER_POOL_START}-{CFG.OPENVPN_ROUTER_POOL_END}."
        )


def validate_remote_lan_cidr(cidr: str) -> str:
    normalized = normalize_cidr(cidr)
    remote = ipaddress.ip_network(normalized, strict=False)
    blocked = [tunnel_network()]
    blocked.extend(ipaddress.ip_network(c, strict=False) for c in cidr_list(CFG.CENTRAL_LAN_CIDRS))
    blocked.extend(ipaddress.ip_network(c, strict=False) for c in cidr_list(CFG.VIPNET_TARGET_CIDRS))
    blocked.extend(legacy_networks())
    for other in blocked:
        if remote.overlaps(other):
            raise SystemExit(f"Ошибка: remote LAN {normalized} пересекается с {other}.")
    return normalized


def validate_client_network_plan(client_type: str, vpn_ip: str = "", remote_lan_cidr: str = "") -> str:
    client_type = normalize_client_type(client_type)
    if client_type == "user":
        if vpn_ip:
            validate_vpn_ip(vpn_ip, client_type)
        if remote_lan_cidr:
            raise SystemExit("Ошибка: remote LAN допустим только для роутеров.")
        return ""
    if not vpn_ip:
        raise SystemExit("Ошибка: для роутера нужен фиксированный VPN IP.")
    validate_vpn_ip(vpn_ip, client_type)
    if client_type == "router_site_to_site":
        if not remote_lan_cidr:
            raise SystemExit("Ошибка: для router_site_to_site нужен remote LAN CIDR.")
        return validate_remote_lan_cidr(remote_lan_cidr)
    return normalize_cidr(remote_lan_cidr) if remote_lan_cidr else ""


def ensure_dirs() -> None:
    for p in [
        CFG.path("OUT_DIR"),
        CFG.path("CCD_DIR"),
        CFG.path("ARCHIVE_DIR"),
        Path(CFG.REGISTRY_DB).parent,
        Path(CFG.NETWORKS_DB).parent,
        Path(CFG.NETWORK_TEMPLATES_DB).parent,
    ]:
        p.mkdir(parents=True, exist_ok=True)


def lock_exclusive() -> Any:
    lock_path = Path(CFG.LOCK_FILE)
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    fh = lock_path.open("w")
    if fcntl is not None:
        fcntl.flock(fh, fcntl.LOCK_EX)
    return fh


def atomic_write(path: Path, content: str, mode: int = 0o600) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(prefix=path.name + ".tmp.", dir=str(path.parent))
    tmp_path = Path(tmp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(content)
        os.chmod(tmp_path, mode)
        os.replace(tmp_path, path)
    finally:
        if tmp_path.exists():
            try:
                tmp_path.unlink()
            except OSError:
                pass


def make_download_file_readable(path: Path) -> None:
    group_name = str(CFG.values.get("DOWNLOAD_FILE_GROUP") or CFG.values.get("MANAGEMENT_CLIENT_GROUP") or "")
    if grp is not None and group_name:
        try:
            os.chown(path, -1, grp.getgrnam(group_name).gr_gid)
        except (KeyError, PermissionError, OSError):
            pass
    os.chmod(path, 0o640)


def write_ccd_file(path: Path, content: str) -> None:
    atomic_write(path, content, CCD_FILE_MODE)


def read_json_file(path: Path, default: Any) -> Any:
    if not path.exists():
        return default
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return default


def write_json_file(path: Path, data: Any, mode: int = 0o600) -> None:
    atomic_write(path, json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n", mode)


def backup_file(path: Path) -> Optional[Path]:
    if not path.exists():
        return None
    backup = path.with_name(path.name + f".backup.{timestamp()}")
    shutil.copy2(path, backup)
    return backup


def backup_server_conf(path: Path) -> Optional[Path]:
    if not path.exists():
        return None
    backup = path.with_name(path.name + f".bak.{timestamp()}")
    shutil.copy2(path, backup)
    return backup


def append_operation_log(line: str) -> None:
    try:
        log_path = Path(CFG.OPERATION_LOG)
        log_path.parent.mkdir(parents=True, exist_ok=True)
        with log_path.open("a", encoding="utf-8") as f:
            f.write(line.rstrip() + "\n")
    except Exception:
        pass

