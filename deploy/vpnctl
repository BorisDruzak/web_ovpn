    return rows


def service_status() -> Dict[str, Any]:
    data: Dict[str, Any] = {}
    for svc_key, svc in [("openvpn", CFG.SERVICE_NAME), ("nat", CFG.NAT_SERVICE)]:
        proc = run(["systemctl", "is-active", svc], check=False)
