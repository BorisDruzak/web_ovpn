def normalize_cidr(cidr: str) -> str:
    try:
        net = ipaddress.ip_network(cidr, strict=False)
    except ValueError as e:
        raise SystemExit(f"Ошибка: неверный CIDR {cidr}: {e}")
    if net.version != 4:
        raise SystemExit(f"Ошибка: поддерживается только IPv4: {cidr}")
    return str(net)


def normalize_tag(tag: str) -> str:
    value = (tag or "default").strip()
    if not value:
        value = "default"
    return value[:80]


def normalize_template_name(name: str) -> str:
    value = (name or "").strip()
    if not value or not CLIENT_RE.match(value):
        raise SystemExit("Ошибка: имя шаблона должно содержать только латиницу, цифры, точку, дефис или подчёркивание.")
    return value


def read_legacy_vipnet_nets() -> List[str]:
    p = CFG.path("VIPNET_NETS_FILE")
    if not p.exists():
        return []
    nets: List[str] = []
    for raw in p.read_text(encoding="utf-8", errors="replace").splitlines():
        line = raw.split("#", 1)[0].strip()
        if not line:
            continue
        nets.append(normalize_cidr(line))
    return nets


def default_network_rows() -> List[Dict[str, Any]]:
    rows: Dict[str, Dict[str, Any]] = {}

    def add(cidr: str, tag: str, nat: bool = False, comment: str = "") -> None:
        normalized = normalize_cidr(cidr)
        rows[normalized] = {
            "cidr": normalized,
            "tag": normalize_tag(tag),
            "nat": bool(nat),
            "comment": comment,
            "source": "builtin",
        }

    add(CFG.DIRECTUM_IP, "directum", False, "Directum")
    add(CFG.EXTRA_DIRECTUM_IP, "directum", False, "Directum 17")
    add(CFG.DNS_IP, "dns", False, "DNS")
    add("192.168.100.0/23", "lan", False, "LAN")
    add("10.83.1.0/24", "lan", False, "LAN")
    add("10.10.10.0/23", "lan", False, "LAN")
    for cidr in read_legacy_vipnet_nets():
        add(cidr, "vipnet", True, "Imported from vipnet-nets.conf")
    return sorted(rows.values(), key=lambda row: (row["tag"], row["cidr"]))


def normalize_network_row(row: Dict[str, Any], source_default: str = "custom") -> Dict[str, Any]:
    return {
        "cidr": normalize_cidr(str(row.get("cidr") or "")),
        "tag": normalize_tag(str(row.get("tag") or "default")),
        "nat": bool(row.get("nat", False)),
        "comment": str(row.get("comment") or ""),
        "source": str(row.get("source") or source_default),
    }


def list_networks() -> List[Dict[str, Any]]:
    raw = read_json_file(CFG.path("NETWORKS_DB"), None)
    if raw is None:
        rows = default_network_rows()
    elif isinstance(raw, dict):
        rows = [normalize_network_row(item) for item in raw.get("networks", []) if isinstance(item, dict)]
    elif isinstance(raw, list):
        rows = [normalize_network_row(item) for item in raw if isinstance(item, dict)]
    else:
        rows = default_network_rows()
    dedup: Dict[str, Dict[str, Any]] = {}
    for row in rows:
        dedup[row["cidr"]] = row
    return sorted(dedup.values(), key=lambda row: (row["tag"], row["cidr"]))


def sync_nat_file_from_networks(rows: List[Dict[str, Any]]) -> None:
    nat_nets = [row["cidr"] for row in rows if row.get("nat")]
    content = "\n".join(sorted(nat_nets)) + ("\n" if nat_nets else "")
    atomic_write(CFG.path("VIPNET_NETS_FILE"), content, 0o644)


def save_networks(rows: List[Dict[str, Any]], sync_nat: bool = True) -> None:
    normalized = [normalize_network_row(row) for row in rows]
    write_json_file(CFG.path("NETWORKS_DB"), {"networks": sorted(normalized, key=lambda row: (row["tag"], row["cidr"]))})
    if sync_nat:
        sync_nat_file_from_networks(normalized)


def add_or_update_network(cidr: str, tag: str, nat: bool, comment: str = "", restart_nat: bool = False) -> Dict[str, Any]:
    normalized = normalize_cidr(cidr)
    rows = list_networks()
    updated = False
    for row in rows:
        if row["cidr"] == normalized:
            row.update({"tag": normalize_tag(tag), "nat": bool(nat), "comment": comment, "source": "custom"})
            updated = True
            network = row
            break
    else:
        network = {"cidr": normalized, "tag": normalize_tag(tag), "nat": bool(nat), "comment": comment, "source": "custom"}
        rows.append(network)
    save_networks(rows)
    result = {"status": "ok", "changed": True, "updated": updated, "network": network}
    if restart_nat:
        proc = run(["systemctl", "restart", CFG.NAT_SERVICE], check=False)
        result["restart_nat"] = {"returncode": proc.returncode, "stdout": proc.stdout, "stderr": proc.stderr}
    record_operation("network-upsert", None, "ok", f"network={normalized} tag={tag} nat={nat}")
    return result


def remove_network(cidr: str, restart_nat: bool = False) -> Dict[str, Any]:
    normalized = normalize_cidr(cidr)
    rows = list_networks()
    new_rows = [row for row in rows if row["cidr"] != normalized]
    changed = len(new_rows) != len(rows)
    if changed:
        save_networks(new_rows)
    result = {"status": "ok", "network": normalized, "changed": changed}
    if restart_nat:
        proc = run(["systemctl", "restart", CFG.NAT_SERVICE], check=False)
        result["restart_nat"] = {"returncode": proc.returncode, "stdout": proc.stdout, "stderr": proc.stderr}
    record_operation("network-remove", None, "ok", f"network={normalized} changed={changed}")
    return result


def read_vipnet_nets() -> List[str]:
    return [row["cidr"] for row in list_networks() if row.get("nat")]


def route_line(cidr_or_ip: str) -> str:
    if "/" not in cidr_or_ip:
        network = ipaddress.ip_network(cidr_or_ip + "/32", strict=False)
    else:
        network = ipaddress.ip_network(cidr_or_ip, strict=False)
    return f'push "route {network.network_address} {network.netmask}"'


def profile_ccd_lines(
    profile: str,
    vpn_ip: str = "",
    client_type: str = "user",
    remote_lan_cidr: str = "",
) -> List[str]:
    validate_profile(profile)
    client_type = normalize_client_type(client_type)
    remote_lan_cidr = validate_client_network_plan(client_type, vpn_ip, remote_lan_cidr)
    lines: List[str] = []
    if vpn_ip:
        lines.append(f"ifconfig-push {vpn_ip} 255.255.255.0")
    if client_type == "router_site_to_site" and remote_lan_cidr:
        remote = ipaddress.ip_network(remote_lan_cidr, strict=False)
        lines.append(f"iroute {remote.network_address} {remote.netmask}")

    def directum() -> None:
        lines.append(route_line(CFG.DIRECTUM_IP))

    def directum17() -> None:
        directum()
        lines.append(route_line(CFG.EXTRA_DIRECTUM_IP))

    def dns() -> None:
        lines.append(route_line(CFG.DNS_IP))
        lines.append(f'push "dhcp-option DNS {CFG.DNS_IP}"')
        lines.append(f'push "dhcp-option DOMAIN {CFG.DNS_DOMAIN}"')

    def vipnet_routes() -> None:
        for net in read_vipnet_nets():
            lines.append(route_line(net))

    if profile in {"directum", "directum_hosts"}:
        directum()
    elif profile == "directum_dns":
        directum(); dns()
    elif profile in {"directum17", "directum17_hosts"}:
        directum17()
    elif profile == "directum17_dns":
        directum17(); dns()
    elif profile == "vipnet_only":
        vipnet_routes()
    elif profile == "vipnet_only_dns":
        dns(); vipnet_routes()
    elif profile == "directum_vipnet":
        directum(); vipnet_routes()
    elif profile in {"directum_vipnet_dns", "vipnet", "router_vipnet"}:
        directum(); dns(); vipnet_routes()
    elif profile == "directum17_vipnet":
        directum17(); vipnet_routes()
    elif profile == "directum17_vipnet_dns":
        directum17(); dns(); vipnet_routes()
    elif profile == "lan_full":
        lines.append(route_line("192.168.100.0/23"))
        lines.append(route_line("10.83.1.0/24"))
        lines.append(route_line("10.10.10.0/23"))
        dns()
    else:
        # Should be unreachable because validate_profile was already called.
        raise SystemExit(f"Ошибка: неизвестный профиль: {profile}")
    return lines


def ccd_content(
    profile: str,
    vpn_ip: str = "",
    client_type: str = "user",
    remote_lan_cidr: str = "",
) -> str:
    return "\n".join(profile_ccd_lines(profile, vpn_ip, client_type=client_type, remote_lan_cidr=remote_lan_cidr)) + "\n"


def unique_cidrs(cidrs: Iterable[str]) -> List[str]:
    seen = set()
    result = []
    for cidr in cidrs:
        normalized = normalize_cidr(str(cidr))
        if normalized not in seen:
            seen.add(normalized)
            result.append(normalized)
    return result


def available_network_cidrs() -> set[str]:
    return {row["cidr"] for row in list_networks()}


def ccd_content_from_networks(cidrs: Iterable[str], vpn_ip: str = "", dns: bool = False) -> str:
    if vpn_ip:
        validate_vpn_ip(vpn_ip)
    selected = unique_cidrs(cidrs)
    lines: List[str] = []
    if vpn_ip:
        lines.append(f"ifconfig-push {vpn_ip} 255.255.255.0")
    for cidr in selected:
        lines.append(route_line(cidr))
    dns_cidr = normalize_cidr(CFG.DNS_IP)
    if dns and dns_cidr not in selected:
        lines.append(route_line(CFG.DNS_IP))
    if dns:
        lines.append(f'push "dhcp-option DNS {CFG.DNS_IP}"')
        lines.append(f'push "dhcp-option DOMAIN {CFG.DNS_DOMAIN}"')
    return "\n".join(lines) + "\n"


def server_route_line(cidr: str) -> str:
    net = ipaddress.ip_network(normalize_cidr(cidr), strict=False)
    return f"route {net.network_address} {net.netmask}"


def read_site_routes_from_text(text: str) -> List[Dict[str, str]]:
    in_block = False
    rows: List[Dict[str, str]] = []
    for raw in text.splitlines():
        line = raw.strip()
        if line == SITE_ROUTES_BEGIN:
            in_block = True
            continue
        if line == SITE_ROUTES_END:
            in_block = False
            continue
        if not in_block or not line or line.startswith("#"):
            continue
        parts = line.split()
        if len(parts) >= 3 and parts[0] == "route":
            try:
                net = ipaddress.ip_network(f"{parts[1]}/{parts[2]}", strict=False)
            except ValueError:
                continue
            rows.append({"cidr": str(net), "line": f"route {net.network_address} {net.netmask}"})
    return rows


def site_routes() -> List[Dict[str, str]]:
    path = CFG.path("SERVER_CONF")
    text = path.read_text(encoding="utf-8", errors="replace") if path.exists() else ""
    return read_site_routes_from_text(text)


def write_site_routes(routes: Iterable[str]) -> Dict[str, Any]:
    path = CFG.path("SERVER_CONF")
    current = path.read_text(encoding="utf-8", errors="replace") if path.exists() else ""
    route_lines = [server_route_line(cidr) for cidr in unique_cidrs(routes)]
    output: List[str] = []
    in_block = False
    block_written = False
    for raw in current.splitlines():
        stripped = raw.strip()
        if stripped == SITE_ROUTES_BEGIN:
            if not block_written:
                output.append(SITE_ROUTES_BEGIN)
                output.extend(route_lines)
                output.append(SITE_ROUTES_END)
                block_written = True
            in_block = True
            continue
        if stripped == SITE_ROUTES_END:
            in_block = False
            continue
        if not in_block:
            output.append(raw)
    if not block_written:
        if output and output[-1].strip():
            output.append("")
        output.append(SITE_ROUTES_BEGIN)
        output.extend(route_lines)
        output.append(SITE_ROUTES_END)
    new_text = "\n".join(output).rstrip() + "\n"
    changed = new_text != current
    backup = None
    if changed:
        backup = backup_server_conf(path)
        atomic_write(path, new_text, 0o644)
    return {
        "changed": changed,
        "backup_path": str(backup) if backup else None,
        "site_routes": site_routes(),
    }


def add_site_route(cidr: str, client: str = "", restart: bool = False) -> Dict[str, Any]:
    if client:
        validate_client(client)
    normalized = validate_remote_lan_cidr(cidr)
    existing = [row["cidr"] for row in site_routes()]
    before = set(existing)
    result = write_site_routes(existing + [normalized])
    result.update({"status": "ok", "cidr": normalized, "client": client or None, "changed": normalized not in before})
    if restart:
        result["restart"] = restart_openvpn_service()
    record_operation("site-route-add", client or None, "ok", f"cidr={normalized} changed={result['changed']}")
    return result


def remove_site_route(cidr: str, restart: bool = False) -> Dict[str, Any]:
    normalized = normalize_cidr(cidr)
    existing = [row["cidr"] for row in site_routes()]
    result = write_site_routes([row for row in existing if row != normalized])
    result.update({"status": "ok", "cidr": normalized, "changed": normalized in set(existing)})
    if restart:
        result["restart"] = restart_openvpn_service()
    record_operation("site-route-remove", None, "ok", f"cidr={normalized} changed={result['changed']}")
    return result


