def is_revoked(client: str) -> bool:
    return cert_status(client) == "revoked"


def update_crl() -> Dict[str, Any]:
    result: Dict[str, Any] = {}
    proc = run(["./easyrsa", "gen-crl"], cwd=CFG.path("EASYRSA_DIR"), env={"EASYRSA_BATCH": "1"})
    result["gen_crl_stdout"] = proc.stdout[-4000:]
    result["gen_crl_stderr"] = proc.stderr[-4000:]
    src = CFG.path("PKI_DIR") / "crl.pem"
    dst = CFG.path("OPENVPN_DIR") / "crl.pem"
    if src.exists():
        shutil.copy2(src, dst)
        os.chmod(dst, 0o644)
        result["crl_installed"] = str(dst)
    else:
        result["crl_warning"] = f"{src} не найден после gen-crl"
    return result


def revoke_cert(client: str) -> Dict[str, Any]:
    validate_client(client)
    status_before = cert_status(client)
    result: Dict[str, Any] = {"client": client, "cert_status_before": status_before, "actions": []}
    if status_before == "missing":
        result["warning"] = "сертификат не найден в PKI index.txt"
        return result
    if status_before == "revoked":
        result["actions"].append("already_revoked")
        result.update(update_crl())
        return result
    proc = run(["./easyrsa", "revoke", client], cwd=CFG.path("EASYRSA_DIR"), env={"EASYRSA_BATCH": "1"})
    result["actions"].append("revoked")
    result["revoke_stdout"] = proc.stdout[-4000:]
    result["revoke_stderr"] = proc.stderr[-4000:]
    result.update(update_crl())
    result["cert_status_after"] = cert_status(client)
    return result


def archive_one(client: str, path: Path, purge: bool = False, archive_root: Optional[Path] = None) -> Optional[str]:
    if not path.exists():
        return None
    if purge:
        path.unlink()
        return f"purged:{path}"
    root = archive_root or (CFG.path("ARCHIVE_DIR") / f"{client}_{timestamp()}")
    root.mkdir(parents=True, exist_ok=True)
    dest = root / path.name
    # Avoid overwrite inside same archive.
    if dest.exists():
        dest = root / f"{path.name}.{timestamp()}"
    shutil.move(str(path), str(dest))
    os.chmod(dest, 0o600)
    return str(dest)


def disable_or_delete(client: str, mode: str, purge: bool = False, reason: str = "", kill_active: bool = False) -> Dict[str, Any]:
    validate_client(client)
    paths = client_paths(client)
    result: Dict[str, Any] = {"client": client, "mode": mode, "purge": purge, "actions": []}
    result["revoke"] = revoke_cert(client)
    result["actions"].append("certificate_revoked_or_already_revoked")

    archive_root = CFG.path("ARCHIVE_DIR") / f"{client}_{mode}_{timestamp()}"
    moved: List[str] = []
    active_files = [paths["ccd"], paths["ovpn"], paths["tlscrypt"], paths["bat"], paths["share_ovpn"], paths["share_bat"]]
    for p in active_files:
        archived = archive_one(client, p, purge=purge, archive_root=archive_root)
        if archived:
            moved.append(archived)
    result["files"] = moved

    status = "disabled" if mode == "disable" else "deleted"
    row = {
        "name": client,
        "profile": (get_client_row(client) or {}).get("profile") if get_client_row(client) else None,
        "detected_profile": None,
        "vpn_ip": parse_ccd(paths["ccd"]).get("vpn_ip") if paths["ccd"].exists() else None,
        "status": status,
        "updated_at": now_iso(),
        "ovpn_path": str(paths["ovpn"]),
        "ccd_path": str(paths["ccd"]),
        "tlscrypt_path": str(paths["tlscrypt"]),
        "bat_path": str(paths["bat"]),
        "share_ovpn_path": str(paths["share_ovpn"]),
        "comment": reason,
        "cert_exists": int(paths["crt"].exists()),
        "key_exists": int(paths["key"].exists()),
        "ccd_exists": int(paths["ccd"].exists()),
        "ovpn_exists": int(paths["ovpn"].exists()),
    }
    upsert_client(row)
    if kill_active:
        try:
            result["kill_active"] = management_kill_client(client, reason=reason or mode)
        except Exception as exc:
            result["kill_active"] = {
                "status": "warning",
                "killed": False,
                "message": "profile disabled, but active session could not be killed because management interface is unavailable",
                "detail": repr(exc),
            }
            result.setdefault("warnings", []).append(result["kill_active"]["message"])
    record_operation(mode, client, "ok", f"purge={purge} kill_active={kill_active} reason={reason}")
    return result

