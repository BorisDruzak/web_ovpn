def run_optional(cmd: List[str]) -> subprocess.CompletedProcess:
    try:
        return run(cmd, check=False)
    except FileNotFoundError as exc:
        return subprocess.CompletedProcess(cmd, 127, "", str(exc))


def service_active_enabled(service: str) -> Dict[str, Any]:
    active = run_optional(["systemctl", "is-active", service])
    enabled = run_optional(["systemctl", "is-enabled", service])
    return {
        "name": service,
        "active": active.returncode == 0 and active.stdout.strip() == "active",
        "enabled": enabled.returncode == 0 and enabled.stdout.strip() == "enabled",
        "active_raw": (active.stdout or active.stderr).strip(),
        "enabled_raw": (enabled.stdout or enabled.stderr).strip(),
    }


def nat_chain_status() -> Dict[str, Any]:
    proc = run_optional(["iptables", "-t", "nat", "-L", CFG.NAT_CHAIN, "-n", "-v", "--line-numbers"])
    output = (proc.stdout or proc.stderr).splitlines()
    return {
        "name": CFG.NAT_CHAIN,
        "exists": proc.returncode == 0,
        "returncode": proc.returncode,
        "output": output,
    }


def nat_status() -> Dict[str, Any]:
    service = service_active_enabled(CFG.NAT_SERVICE)
    chain = nat_chain_status()
    warnings: List[str] = []
    if service["active"] or service["enabled"] or chain["exists"]:
        warnings.append("Legacy SNAT is active. Current routing design expects no NAT for 192.168.50.0/24.")
    return {
        "status": "ok",
        "mode": "disabled_expected",
        "legacy_nat_service": service,
        "legacy_chain": chain,
        "warnings": warnings,
    }


def disable_legacy_nat() -> Dict[str, Any]:
    actions: List[Dict[str, Any]] = []
    service = run_optional(["systemctl", "disable", "--now", CFG.NAT_SERVICE])
    actions.append({"command": service.args, "returncode": service.returncode, "stdout": service.stdout, "stderr": service.stderr})
    jump = run_optional(["iptables", "-t", "nat", "-D", "POSTROUTING", "-j", CFG.NAT_CHAIN])
    actions.append({"command": jump.args, "returncode": jump.returncode, "stdout": jump.stdout, "stderr": jump.stderr})
    flush = run_optional(["iptables", "-t", "nat", "-F", CFG.NAT_CHAIN])
    actions.append({"command": flush.args, "returncode": flush.returncode, "stdout": flush.stdout, "stderr": flush.stderr})
    delete = run_optional(["iptables", "-t", "nat", "-X", CFG.NAT_CHAIN])
    actions.append({"command": delete.args, "returncode": delete.returncode, "stdout": delete.stdout, "stderr": delete.stderr})
    status = nat_status()
    record_operation("nat-disable-legacy", None, "ok", f"chain={CFG.NAT_CHAIN} service={CFG.NAT_SERVICE}")
    return {"status": "ok", "actions": actions, "nat_status": status}


def route_exists_for_cidr(cidr: str, routes: Optional[List[Dict[str, str]]] = None) -> bool:
    normalized = normalize_cidr(cidr)
    rows = routes if routes is not None else site_routes()
    return any(row["cidr"] == normalized for row in rows)


def validate_network_plan() -> Dict[str, Any]:
    warnings: List[str] = []
    errors: List[str] = []
    server = inspect_server_config()
    warnings.extend(server.get("warnings", []))
    nat = nat_status()
    warnings.extend(nat.get("warnings", []))

    fixed_ips: Dict[str, str] = {}
    remote_lans: Dict[str, str] = {}
    routes = site_routes()
    ccd_dir = CFG.path("CCD_DIR")
    if ccd_dir.exists():
        for path in sorted(ccd_dir.iterdir()):
            if not path.is_file() or ".backup." in path.name:
                continue
            parsed = parse_ccd(path)
            raw = parsed.get("raw", "")
            legacy_hits = sorted(set(re.findall(r"\b10\.8\.\d{1,3}\.\d{1,3}\b", raw)))
            for hit in legacy_hits:
                warnings.append(f"legacy VPN IP {hit} found in CCD {path}")
            vpn_ip = parsed.get("vpn_ip")
            if vpn_ip:
                try:
                    addr = ipaddress.ip_address(str(vpn_ip))
                    if any(addr in legacy for legacy in legacy_networks()):
                        warnings.append(f"legacy fixed VPN IP {vpn_ip} found in CCD {path}")
                    elif addr not in tunnel_network():
                        errors.append(f"fixed VPN IP {vpn_ip} in {path} is outside {tunnel_network()}")
                    if str(addr) in fixed_ips:
                        errors.append(f"duplicate fixed VPN IP {addr}: {fixed_ips[str(addr)]} and {path}")
                    fixed_ips[str(addr)] = str(path)
                except ValueError:
                    errors.append(f"invalid fixed VPN IP {vpn_ip} in {path}")
            for remote in sorted(parsed.get("iroutes", [])):
                try:
                    validate_remote_lan_cidr(remote)
                except SystemExit as exc:
                    errors.append(f"{path}: {exc.code}")
                if remote in remote_lans:
                    errors.append(f"duplicate remote LAN {remote}: {remote_lans[remote]} and {path}")
                remote_lans[remote] = str(path)
                if not route_exists_for_cidr(remote, routes):
                    warnings.append(f"remote LAN {remote} from {path} has no managed server route")

    status = "error" if errors else ("warning" if warnings else "ok")
    return {
        "status": status,
        "addressing": {
            "openvpn_tunnel_cidr": str(tunnel_network()),
            "server_tunnel_ip": CFG.OPENVPN_SERVER_TUNNEL_IP,
            "user_pool": {"start": CFG.OPENVPN_USER_POOL_START, "end": CFG.OPENVPN_USER_POOL_END},
            "router_pool": {"start": CFG.OPENVPN_ROUTER_POOL_START, "end": CFG.OPENVPN_ROUTER_POOL_END},
            "remote_site_cidrs": cidr_list(CFG.REMOTE_SITE_CIDRS),
            "legacy_cidrs": cidr_list(CFG.OPENVPN_LEGACY_CIDRS),
        },
        "server_config": server,
        "nat_status": nat,
        "site_routes": routes,
        "warnings": warnings,
        "errors": errors,
    }


def reconnect_client(client: str, reason: str = "") -> Dict[str, Any]:
    validate_client(client)
    try:
        result = management_kill_client(client, reason=reason)
    except Exception as exc:
        result = {
            "status": "not_configured",
            "client": client,
            "killed": False,
            "message": f"OpenVPN management interface is unavailable: {exc!r}",
        }
        record_operation("reconnect-client", client, "warning", repr(exc))
        return result
    if result.get("killed"):
        result["message"] = "client will reconnect and reload CCD"
    else:
        result["status"] = "not_connected"
    record_operation("reconnect-client", client, "ok", reason or result.get("message", ""))
    return result

