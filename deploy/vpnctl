def parse_status_log() -> List[Dict[str, Any]]:
    path = CFG.path("STATUS_LOG")
    if not path.exists():
        return []
    return parse_status_log_text(path.read_text(encoding="utf-8", errors="replace"))


def parse_status_log_text(text: str) -> List[Dict[str, Any]]:
    rows: List[Dict[str, Any]] = []
    for line in text.splitlines():
        if line.startswith("CLIENT_LIST,"):
            parts = list(csv.reader([line]))[0]
            # status-version 2 usually has 13 fields.
            row = {
                "common_name": parts[1] if len(parts) > 1 else "",
                "real_address": parts[2] if len(parts) > 2 else "",
                "virtual_address": parts[3] if len(parts) > 3 else "",
                "bytes_received": int(parts[4]) if len(parts) > 4 and parts[4].isdigit() else None,
                "bytes_sent": int(parts[5]) if len(parts) > 5 and parts[5].isdigit() else None,
                "connected_since": parts[6] if len(parts) > 6 else "",
                "username": parts[8] if len(parts) > 8 else "",
                "client_id": parts[9] if len(parts) > 9 else "",
                "peer_id": parts[10] if len(parts) > 10 else "",
                "cipher": parts[12] if len(parts) > 12 else "",
            }
            rows.append(row)
    # Legacy status without CLIENT_LIST CSV: intentionally minimal.
    return rows


def connected_clients_result(source: str = "auto", include_registry: bool = True) -> Dict[str, Any]:
    if source not in {"auto", "management", "status-log", "status_log"}:
        raise SystemExit("Ошибка: source должен быть auto, management или status-log.")
    if source in {"auto", "management"}:
        try:
            rows = management_status_clients()
            if include_registry:
                add_registry_to_connected(rows)
            return {"status": "ok", "source": "management", "connected": rows}
        except Exception as exc:
            if source == "management":
                return {"status": "error", "source": "management", "connected": [], "message": repr(exc)}
    rows = parse_status_log()
    if include_registry:
        add_registry_to_connected(rows)
    return {"status": "ok", "source": "status_log", "connected": rows}


def connected_clients(include_registry: bool = True) -> List[Dict[str, Any]]:
    return connected_clients_result(source="auto", include_registry=include_registry)["connected"]


def connected_clients_from_status_log(include_registry: bool = True) -> List[Dict[str, Any]]:
