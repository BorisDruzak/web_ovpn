SERVER_DIRECTIVES = {"status", "status-version", "management", "management-client-group", "management-log-cache"}


def validate_status_interval(value: int) -> int:
    if value < 5 or value > 300:
        raise SystemExit("Ошибка: status interval должен быть в диапазоне 5-300 секунд.")
    return value


def validate_status_version(value: int) -> int:
    if value not in {2, 3}:
        raise SystemExit("Ошибка: status-version может быть только 2 или 3.")
    return value


def validate_management_socket_path(value: str) -> str:
    path = (value or "").strip()
    if not path:
        raise SystemExit("Ошибка: management socket path не может быть пустым.")
    if re.match(r"^(?:\d{1,3}\.){3}\d{1,3}:\d+$", path) or path.lower().startswith(("tcp:", "localhost:", "0.0.0.0:")):
        raise SystemExit("Ошибка: TCP management interface запрещён; используйте Unix socket.")
    if not (Path(path).is_absolute() or path.startswith("/")):
        raise SystemExit("Ошибка: management socket должен быть абсолютным Unix path.")
    return path


def parse_server_config_text(text: str) -> Dict[str, Any]:
    settings: Dict[str, Any] = {
        "server_network": "",
        "server_tunnel_ip": CFG.OPENVPN_SERVER_TUNNEL_IP,
        "status_path": "",
        "status_interval": None,
        "status_version": None,
        "management_enabled": False,
        "management_socket": "",
        "management_client_group": "",
        "management_log_cache": None,
    }
    warnings: List[str] = []
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or line.startswith(";"):
            continue
        parts = line.split()
        if not parts:
            continue
        key = parts[0]
        if key == "server" and len(parts) >= 3:
            try:
                net = ipaddress.ip_network(f"{parts[1]}/{parts[2]}", strict=False)
                settings["server_network"] = str(net)
                if any(net == legacy for legacy in legacy_networks()):
                    warnings.append(f"legacy OpenVPN server pool is configured: {net}")
                elif net != tunnel_network():
                    warnings.append(f"OpenVPN server pool {net} differs from expected {tunnel_network()}")
            except ValueError:
                warnings.append(f"invalid server directive: {line}")
        elif key == "status" and len(parts) >= 2:
            settings["status_path"] = parts[1]
            if len(parts) >= 3:
                try:
                    settings["status_interval"] = int(parts[2])
                except ValueError:
                    warnings.append(f"invalid status interval: {parts[2]}")
        elif key == "status-version" and len(parts) >= 2:
            try:
                settings["status_version"] = int(parts[1])
            except ValueError:
                warnings.append(f"invalid status-version: {parts[1]}")
        elif key == "management":
            if len(parts) >= 3 and parts[2] == "unix":
                settings["management_enabled"] = True
                settings["management_socket"] = parts[1]
            else:
                warnings.append("TCP management directive is present and ignored by vpnctl")
        elif key == "management-client-group" and len(parts) >= 2:
            settings["management_client_group"] = parts[1]
        elif key == "management-log-cache" and len(parts) >= 2:
            try:
                settings["management_log_cache"] = int(parts[1])
            except ValueError:
                warnings.append(f"invalid management-log-cache: {parts[1]}")
    return {"settings": settings, "warnings": warnings}


def inspect_server_config() -> Dict[str, Any]:
    path = CFG.path("SERVER_CONF")
    text = path.read_text(encoding="utf-8", errors="replace") if path.exists() else ""
    parsed = parse_server_config_text(text)
    settings = parsed["settings"]
    settings["server_network"] = settings["server_network"] or str(tunnel_network())
    settings["server_tunnel_ip"] = settings["server_tunnel_ip"] or CFG.OPENVPN_SERVER_TUNNEL_IP
    settings["status_path"] = settings["status_path"] or CFG.STATUS_LOG
    settings["status_interval"] = settings["status_interval"] or 10
    settings["status_version"] = settings["status_version"] or 2
    settings["management_socket"] = settings["management_socket"] or CFG.MANAGEMENT_SOCKET
    settings["management_client_group"] = settings["management_client_group"] or CFG.MANAGEMENT_CLIENT_GROUP
    settings["management_log_cache"] = settings["management_log_cache"] or int(CFG.MANAGEMENT_LOG_CACHE)
    return {
        "status": "ok",
        "server_conf": str(path),
        "settings": settings,
        "warnings": parsed["warnings"],
    }


def patch_server_config(
    status_interval: Optional[int] = None,
    status_version: Optional[int] = None,
    enable_management: bool = False,
    management_socket: str = "",
    management_client_group: str = "",
    management_log_cache: Optional[int] = None,
    restart: bool = False,
) -> Dict[str, Any]:
    path = CFG.path("SERVER_CONF")
    current_text = path.read_text(encoding="utf-8", errors="replace") if path.exists() else ""
    current = inspect_server_config()["settings"]
    desired = dict(current)
    desired["status_interval"] = validate_status_interval(int(status_interval if status_interval is not None else desired["status_interval"]))
    desired["status_version"] = validate_status_version(int(status_version if status_version is not None else desired["status_version"]))
    if enable_management:
        desired["management_enabled"] = True
    if management_socket:
        desired["management_socket"] = validate_management_socket_path(management_socket)
        desired["management_enabled"] = True
    elif desired.get("management_enabled"):
        desired["management_socket"] = validate_management_socket_path(str(desired["management_socket"]))
    if management_client_group:
        desired["management_client_group"] = normalize_tag(management_client_group)
        desired["management_enabled"] = True
    if management_log_cache is not None:
        if management_log_cache < 1:
            raise SystemExit("Ошибка: management-log-cache должен быть положительным числом.")
        desired["management_log_cache"] = int(management_log_cache)
        desired["management_enabled"] = True

    kept_lines = []
    for raw in current_text.splitlines():
        stripped = raw.strip()
        key = stripped.split(None, 1)[0] if stripped else ""
        if key in SERVER_DIRECTIVES:
            continue
        kept_lines.append(raw)
    if kept_lines and kept_lines[-1].strip():
        kept_lines.append("")
    managed_lines = [
        f"status {desired['status_path']} {desired['status_interval']}",
        f"status-version {desired['status_version']}",
    ]
    if desired.get("management_enabled"):
        managed_lines.extend(
            [
                f"management {desired['management_socket']} unix",
                f"management-client-group {desired['management_client_group']}",
                f"management-log-cache {desired['management_log_cache']}",
            ]
        )
    new_text = "\n".join(kept_lines + managed_lines).rstrip() + "\n"
    changed = new_text != current_text
    backup = None
    if changed:
        backup = backup_server_conf(path)
        atomic_write(path, new_text, 0o644)
    restart_result = None
    if restart:
        restart_result = restart_openvpn_service()
    result = {
        "status": "ok",
        "server_conf": str(path),
        "changed": changed,
        "backup_path": str(backup) if backup else None,
        "settings": desired,
        "changed_directives": managed_lines if changed else [],
    }
    if restart_result is not None:
        result["restart"] = restart_result
    record_operation("server-config-apply", None, "ok", f"changed={changed} restart={restart}")
    return result


def migrate_server_pool(from_cidr: str, to_cidr: str, backup: bool = False, restart: bool = False) -> Dict[str, Any]:
    from_net = ipaddress.ip_network(normalize_cidr(from_cidr), strict=False)
    to_net = ipaddress.ip_network(normalize_cidr(to_cidr), strict=False)
    path = CFG.path("SERVER_CONF")
    current_text = path.read_text(encoding="utf-8", errors="replace") if path.exists() else ""
    from_line = f"server {from_net.network_address} {from_net.netmask}"
    to_line = f"server {to_net.network_address} {to_net.netmask}"
    changed = from_line in current_text
    backup_path = None
    if changed:
        if backup:
            backup_path = backup_server_conf(path)
        atomic_write(path, current_text.replace(from_line, to_line), 0o644)
    restart_result = restart_openvpn_service() if restart and changed else None
    result = {
        "status": "ok",
        "server_conf": str(path),
        "from": str(from_net),
        "to": str(to_net),
        "changed": changed,
        "backup_path": str(backup_path) if backup_path else None,
        "restart": restart_result,
        "settings": inspect_server_config()["settings"],
    }
    record_operation("server-config-migrate-pool", None, "ok", f"{from_net}->{to_net} changed={changed} restart={restart}")
    return result


def restart_openvpn_service() -> Dict[str, Any]:
    proc = run(["systemctl", "restart", CFG.SERVICE_NAME], check=False)
    active = run(["systemctl", "is-active", CFG.SERVICE_NAME], check=False)
    result = {
        "service": CFG.SERVICE_NAME,
        "restart_returncode": proc.returncode,
        "restart_stdout": proc.stdout,
        "restart_stderr": proc.stderr,
        "active": active.stdout.strip(),
        "active_returncode": active.returncode,
    }
    record_operation("server-config-restart-openvpn", None, "ok" if active.returncode == 0 else "error", result["active"])
    return result


def management_socket_path() -> str:
    inspected = inspect_server_config()["settings"]
    return str(inspected.get("management_socket") or CFG.MANAGEMENT_SOCKET)


def parse_management_status(text: str) -> List[Dict[str, Any]]:
    rows: Dict[str, Dict[str, Any]] = {}
    lines = text.splitlines()
    for line in lines:
        if line.startswith("CLIENT_LIST,"):
            parts = list(csv.reader([line]))[0]
            common_name = parts[1] if len(parts) > 1 else ""
            if not common_name:
                continue
            if len(parts) > 12 and not parts[4].isdigit():
                rx_idx, tx_idx, since_idx = 5, 6, 7
            else:
                rx_idx, tx_idx, since_idx = 4, 5, 6
            rows[common_name] = {
                "common_name": common_name,
                "real_address": parts[2] if len(parts) > 2 else "",
                "virtual_address": parts[3] if len(parts) > 3 else "",
                "bytes_received": int(parts[rx_idx]) if len(parts) > rx_idx and parts[rx_idx].isdigit() else None,
                "bytes_sent": int(parts[tx_idx]) if len(parts) > tx_idx and parts[tx_idx].isdigit() else None,
                "connected_since": parts[since_idx] if len(parts) > since_idx else "",
            }
        elif line.startswith("ROUTING_TABLE,"):
            parts = list(csv.reader([line]))[0]
            if len(parts) >= 3:
                virtual_address, common_name = parts[1], parts[2]
                if common_name in rows:
                    rows[common_name]["virtual_address"] = virtual_address
    client_headers = {"Common Name", "Real Address", "Bytes Received", "Bytes Sent", "Connected Since"}
    route_headers = {"Virtual Address", "Common Name", "Real Address", "Last Ref"}
    mode = ""
    for line in lines:
        parts = next(csv.reader([line]))
        if parts and parts[0] in {"TITLE", "TIME", "HEADER", "CLIENT_LIST", "ROUTING_TABLE", "GLOBAL_STATS"}:
            continue
        header = set(parts)
        if client_headers.issubset(header):
            mode = "clients"
            continue
        if route_headers.issubset(header):
            mode = "routes"
            continue
        if line in {"ROUTING TABLE", "GLOBAL STATS", "END"}:
            if line in {"GLOBAL STATS", "END"}:
                mode = ""
            continue
        if not parts or len(parts) < 2:
            continue
        if mode == "clients" and len(parts) >= 5:
            common_name = parts[0]
            rows.setdefault(common_name, {})
            rows[common_name].update(
                {
                    "common_name": common_name,
                    "real_address": parts[1],
                    "bytes_received": int(parts[2]) if parts[2].isdigit() else None,
                    "bytes_sent": int(parts[3]) if parts[3].isdigit() else None,
                    "connected_since": parts[4],
                }
            )
        elif mode == "routes" and len(parts) >= 2:
            virtual_address, common_name = parts[0], parts[1]
            rows.setdefault(common_name, {"common_name": common_name})
            rows[common_name]["virtual_address"] = virtual_address
            if len(parts) >= 3 and not rows[common_name].get("real_address"):
                rows[common_name]["real_address"] = parts[2]
    result = []
    for row in rows.values():
        result.append(
            {
                "common_name": row.get("common_name", ""),
                "real_address": row.get("real_address", ""),
                "virtual_address": row.get("virtual_address", ""),
                "bytes_received": row.get("bytes_received"),
                "bytes_sent": row.get("bytes_sent"),
                "connected_since": row.get("connected_since", ""),
            }
        )
    return sorted(result, key=lambda item: item["common_name"])


def recv_available(sock: socket.socket, max_bytes: int = 65536) -> str:
    chunks = []
    while True:
        try:
            chunk = sock.recv(4096)
        except socket.timeout:
            break
        if not chunk:
            break
        chunks.append(chunk)
        if sum(len(part) for part in chunks) >= max_bytes:
            break
    return b"".join(chunks).decode("utf-8", errors="replace")


def recv_until(sock: socket.socket, markers: Iterable[str], timeout_chunks: int = 8) -> str:
    text = ""
    markers = list(markers)
    for _ in range(timeout_chunks):
        try:
            chunk = sock.recv(4096)
        except socket.timeout:
            break
        if not chunk:
            break
        text += chunk.decode("utf-8", errors="replace")
        if any(marker in text for marker in markers):
            break
    return text


def open_management_socket(socket_path: Optional[str] = None) -> socket.socket:
    path = validate_management_socket_path(socket_path or management_socket_path())
    if not hasattr(socket, "AF_UNIX"):
        raise OSError("Unix domain sockets are not available on this platform")
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    sock.settimeout(2)
    original_egid = None
    try:
        group_name = str(inspect_server_config()["settings"].get("management_client_group") or "")
        if grp is not None and hasattr(os, "geteuid") and os.geteuid() == 0 and group_name:
            original_egid = os.getegid()
            os.setegid(grp.getgrnam(group_name).gr_gid)
        sock.connect(path)
    finally:
        if original_egid is not None:
            os.setegid(original_egid)
    return sock


def management_status_clients(socket_path: Optional[str] = None) -> List[Dict[str, Any]]:
    with open_management_socket(socket_path) as sock:
        sock.sendall(b"status\n")
        text = recv_until(sock, ["\nEND", "END\r\n"], timeout_chunks=16)
        try:
            sock.sendall(b"quit\n")
        except OSError:
            pass
    return parse_management_status(text)


def management_test(socket_path: Optional[str] = None) -> Dict[str, Any]:
    path = socket_path or management_socket_path()
    try:
        clients = management_status_clients(path)
    except Exception as exc:
        record_operation("management-test", None, "error", repr(exc))
        return {"status": "ok", "socket": path, "available": False, "message": repr(exc)}
    record_operation("management-test", None, "ok", f"socket={path}")
    return {"status": "ok", "socket": path, "available": True, "clients_seen": len(clients)}


def management_status() -> Dict[str, Any]:
    clients = management_status_clients()
    add_registry_to_connected(clients)
    record_operation("management-status", None, "ok", f"clients={len(clients)}")
    return {"status": "ok", "source": "management", "clients": clients}


def management_kill_client(client: str, reason: str = "") -> Dict[str, Any]:
    validate_client(client)
    path = management_socket_path()
    with open_management_socket(path) as sock:
        sock.sendall(b"status\n")
        status_text = recv_until(sock, ["\nEND", "END\r\n"], timeout_chunks=16)
        clients = parse_management_status(status_text)
        if client not in {row.get("common_name") for row in clients}:
            try:
                sock.sendall(b"quit\n")
            except OSError:
                pass
            record_operation("management-kill", client, "ok", "not connected")
            return {"status": "ok", "client": client, "killed": False, "message": "not connected"}
        sock.sendall((f"kill {client}\n").encode("utf-8"))
        kill_text = recv_until(sock, ["SUCCESS:", "ERROR:", "client-kill"], timeout_chunks=8)
        try:
            sock.sendall(b"quit\n")
        except OSError:
            pass
    killed = "SUCCESS" in kill_text.upper() or "CLIENT-KILL" in kill_text.upper()
    result = {
        "status": "ok" if killed else "error",
        "client": client,
        "killed": killed,
        "message": "client will reconnect and reload CCD" if killed else kill_text.strip()[:500],
    }
    record_operation("management-kill", client, result["status"], reason or result["message"])
    return result


def add_registry_to_connected(rows: List[Dict[str, Any]]) -> None:
    with db() as con:
        for row in rows:
            reg = con.execute("SELECT profile,status,vpn_ip FROM clients WHERE name=?", (row["common_name"],)).fetchone()
            if reg:
                row["profile"] = reg["profile"]
                row["registry_status"] = reg["status"]
                row["registry_vpn_ip"] = reg["vpn_ip"]


