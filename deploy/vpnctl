def apply_profile_to_client(client: str, profile: str, vpn_ip: str = "", reason: str = "") -> Dict[str, Any]:
    validate_client(client)
    validate_profile(profile)
    if vpn_ip:
        check_vpn_ip_collision(client, vpn_ip)
    paths = client_paths(client)
    ensure_dirs()
    ccd = ccd_content(profile, vpn_ip)
    backups = []
    for path in [paths["ccd"], paths["bat"]]:
        backup = backup_file(path)
        if backup:
            backups.append(str(backup))
    write_ccd_file(paths["ccd"], ccd)
    actions = ["ccd_written"]
    if profile.endswith("_hosts"):
        atomic_write(paths["bat"], build_hosts_bat(), 0o600)
        actions.append("bat_written")
    elif paths["bat"].exists():
        archived = archive_one(client, paths["bat"], purge=False)
        if archived:
            actions.append("old_bat_archived")
            backups.append(archived)
    row = refresh_client_registry(client, profile=profile, comment=reason)
    result = {
        "status": "ok",
        "client": client,
        "profile": profile,
        "vpn_ip": vpn_ip or row.get("vpn_ip"),
        "ccd_path": str(paths["ccd"]),
        "backups": backups,
        "actions": actions,
        "detected_profile": row.get("detected_profile"),
    }
    record_operation("profile-apply", client, "ok", f"profile={profile} vpn_ip={vpn_ip or '-'} reason={reason}")
    return result


