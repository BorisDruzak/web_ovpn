def repair_client_artifacts(client: str, reason: str = "") -> Dict[str, Any]:
    validate_client(client)
    ensure_dirs()
    paths = client_paths(client)
    cert = cert_status(client)
    if cert != "valid":
        raise SystemExit(f"Ошибка: сертификат клиента не valid: {cert}")
    required = [CFG.path("PKI_DIR") / "ca.crt", paths["crt"], paths["key"]]
    missing = [str(path) for path in required if not path.exists()]
    if missing:
        raise SystemExit("Ошибка: не хватает файлов для восстановления .ovpn: " + ", ".join(missing))

    actions: List[str] = []
    server_tls = CFG.path("OPENVPN_DIR") / "tls-crypt-v2.key"
    if not paths["tlscrypt"].exists():
        if not server_tls.exists():
            raise SystemExit(f"Ошибка: не найден {server_tls}")
        run(["openvpn", "--tls-crypt-v2", str(server_tls), "--genkey", "tls-crypt-v2-client", str(paths["tlscrypt"])])
        os.chmod(paths["tlscrypt"], 0o600)
        actions.append("tlscrypt_generated")
    else:
        actions.append("tlscrypt_reused")

    if not paths["ovpn"].exists():
        atomic_write(paths["ovpn"], build_ovpn(client), 0o600)
        actions.append("ovpn_written")
    else:
        actions.append("ovpn_reused")
    make_download_file_readable(paths["ovpn"])
    actions.append("ovpn_permissions_fixed")

    share = CFG.path("SHARE_OUT_DIR")
    if is_mountpoint(Path("/mnt/antares_soft")) and share.is_dir():
        shutil.copy2(paths["ovpn"], paths["share_ovpn"])
        actions.append("ovpn_copied_to_share")

    row = refresh_client_registry(client, comment=reason)
    result = {
        "status": "ok",
        "client": client,
        "actions": actions,
        "ovpn_path": str(paths["ovpn"]),
        "tlscrypt_path": str(paths["tlscrypt"]),
        "share_ovpn_path": str(paths["share_ovpn"]) if paths["share_ovpn"].exists() else None,
        "detected_profile": row.get("detected_profile"),
    }
    record_operation("repair-artifacts", client, "ok", reason)
    return result

