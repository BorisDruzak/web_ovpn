def registry_value(row: Optional[sqlite3.Row], key: str, default: Any = None) -> Any:
    if row is None:
        return default
    return row[key] if key in row.keys() else default


def normalized_content(content: str) -> str:
    return content if content.endswith("\n") else content + "\n"


def file_payload(path: Path) -> Dict[str, Any]:
    data: Dict[str, Any] = {"path": str(path), "exists": path.exists(), "size": None, "content": ""}
    if path.exists():
        data["size"] = path.stat().st_size
        data["content"] = path.read_text(encoding="utf-8", errors="replace")
    return data


def current_file_registry_row(client: str, profile: Optional[str] = None, comment: str = "") -> Dict[str, Any]:
    paths = client_paths(client)
    existing = get_client_row(client)
    parsed = parse_ccd(paths["ccd"])
    client_type = infer_client_type_from_ccd(parsed)
    remote_lan = sorted(parsed.get("iroutes", []))[0] if parsed.get("iroutes") else None
    detected = infer_profile(client, paths["ccd"], paths["bat"]) if paths["ccd"].exists() else None
    cert = cert_status(client)
    if cert == "valid":
        status = "active"
    elif cert == "revoked":
        status = "revoked"
    else:
        status = registry_value(existing, "status", cert)
    selected_profile = profile or registry_value(existing, "profile")
    if not selected_profile and detected in PROFILE_DESCRIPTIONS:
        selected_profile = detected
    return {
        "name": client,
        "profile": selected_profile,
        "detected_profile": detected,
        "vpn_ip": parsed.get("vpn_ip") or registry_value(existing, "vpn_ip"),
        "client_type": registry_value(existing, "client_type", client_type),
        "remote_lan_cidr": registry_value(existing, "remote_lan_cidr", remote_lan),
        "status": status,
        "updated_at": now_iso(),
        "ovpn_path": str(paths["ovpn"]),
        "ccd_path": str(paths["ccd"]),
        "tlscrypt_path": str(paths["tlscrypt"]),
        "bat_path": str(paths["bat"]) if paths["bat"].exists() else registry_value(existing, "bat_path"),
        "share_ovpn_path": str(paths["share_ovpn"]) if paths["share_ovpn"].exists() else registry_value(existing, "share_ovpn_path"),
        "comment": comment or registry_value(existing, "comment", ""),
        "cert_exists": int(paths["crt"].exists()),
        "key_exists": int(paths["key"].exists()),
        "ccd_exists": int(paths["ccd"].exists()),
        "ovpn_exists": int(paths["ovpn"].exists()),
    }


def refresh_client_registry(client: str, profile: Optional[str] = None, comment: str = "") -> Dict[str, Any]:
