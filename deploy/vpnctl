def db() -> sqlite3.Connection:
    ensure_dirs()
    con = sqlite3.connect(CFG.REGISTRY_DB)
    con.row_factory = sqlite3.Row
    init_db(con)
    return con


def init_db(con: sqlite3.Connection) -> None:
    con.executescript(
        """
        CREATE TABLE IF NOT EXISTS clients (
            name TEXT PRIMARY KEY,
            profile TEXT,
            detected_profile TEXT,
            vpn_ip TEXT,
            client_type TEXT NOT NULL DEFAULT 'user',
            remote_lan_cidr TEXT,
            status TEXT NOT NULL DEFAULT 'active',
            created_at TEXT,
            updated_at TEXT,
            ovpn_path TEXT,
            ccd_path TEXT,
            tlscrypt_path TEXT,
            bat_path TEXT,
            share_ovpn_path TEXT,
            comment TEXT,
            cert_exists INTEGER DEFAULT 0,
            key_exists INTEGER DEFAULT 0,
            ccd_exists INTEGER DEFAULT 0,
            ovpn_exists INTEGER DEFAULT 0
        );
        CREATE TABLE IF NOT EXISTS operations (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            time TEXT NOT NULL,
            actor TEXT,
            action TEXT NOT NULL,
            client TEXT,
            result TEXT NOT NULL,
            message TEXT
        );
        """
    )
    cols = {row[1] for row in con.execute("PRAGMA table_info(clients)").fetchall()}
    if "client_type" not in cols:
        con.execute("ALTER TABLE clients ADD COLUMN client_type TEXT NOT NULL DEFAULT 'user'")
    if "remote_lan_cidr" not in cols:
        con.execute("ALTER TABLE clients ADD COLUMN remote_lan_cidr TEXT")
    con.commit()


def actor() -> str:
    return os.environ.get("SUDO_USER") or os.environ.get("USER") or "unknown"


def record_operation(action: str, client: Optional[str], result: str, message: str = "") -> None:
    line = f"{now_iso()} actor={actor()} action={action} client={client or '-'} result={result} message={message}"
    append_operation_log(line)
    try:
        with db() as con:
            con.execute(
                "INSERT INTO operations(time, actor, action, client, result, message) VALUES (?, ?, ?, ?, ?, ?)",
                (now_iso(), actor(), action, client, result, message),
            )
            con.commit()
    except Exception:
        pass


def upsert_client(row: Dict[str, Any]) -> None:
    row = dict(row)
    row.setdefault("updated_at", now_iso())
    row.setdefault("created_at", row["updated_at"])
    cols = [
        "name", "profile", "detected_profile", "vpn_ip", "client_type", "remote_lan_cidr", "status", "created_at", "updated_at",
        "ovpn_path", "ccd_path", "tlscrypt_path", "bat_path", "share_ovpn_path", "comment",
        "cert_exists", "key_exists", "ccd_exists", "ovpn_exists",
    ]
    for col in cols:
        row.setdefault(col, None)
    row["client_type"] = row.get("client_type") or "user"
    with db() as con:
        existing = con.execute("SELECT created_at FROM clients WHERE name=?", (row["name"],)).fetchone()
        if existing and existing["created_at"]:
            row["created_at"] = existing["created_at"]
        placeholders = ",".join("?" for _ in cols)
        updates = ",".join(f"{c}=excluded.{c}" for c in cols if c != "name")
        con.execute(
            f"INSERT INTO clients({','.join(cols)}) VALUES ({placeholders}) "
            f"ON CONFLICT(name) DO UPDATE SET {updates}",
            [row[c] for c in cols],
        )
        con.commit()


def get_client_row(name: str) -> Optional[sqlite3.Row]:
    with db() as con:
        return con.execute("SELECT * FROM clients WHERE name=?", (name,)).fetchone()

