def normalize_template_row(row: Dict[str, Any], builtin: bool = False) -> Dict[str, Any]:
    cidrs = unique_cidrs(row.get("cidrs", []) if isinstance(row.get("cidrs"), list) else [])
    return {
        "name": normalize_template_name(str(row.get("name") or "")),
        "description": str(row.get("description") or ""),
        "cidrs": cidrs,
        "dns": bool(row.get("dns", False)),
        "builtin": bool(row.get("builtin", builtin)),
    }


def custom_network_templates() -> List[Dict[str, Any]]:
    raw = read_json_file(CFG.path("NETWORK_TEMPLATES_DB"), [])
    if isinstance(raw, dict):
        raw = raw.get("templates", [])
    if not isinstance(raw, list):
        return []
    rows = []
    for item in raw:
        if isinstance(item, dict):
            rows.append(normalize_template_row(item, builtin=False))
    return rows


def list_network_templates() -> List[Dict[str, Any]]:
    rows: Dict[str, Dict[str, Any]] = {row["name"]: row for row in builtin_network_templates()}
    for row in custom_network_templates():
        rows[row["name"]] = row
    return sorted(rows.values(), key=lambda row: (row.get("builtin") is False, row["name"]))


def save_custom_network_templates(rows: List[Dict[str, Any]]) -> None:
    normalized = [normalize_template_row({**row, "builtin": False}, builtin=False) for row in rows]
    write_json_file(CFG.path("NETWORK_TEMPLATES_DB"), {"templates": sorted(normalized, key=lambda row: row["name"])})


def add_network_template(name: str, cidrs: List[str], description: str = "", dns: bool = False) -> Dict[str, Any]:
    name = normalize_template_name(name)
    if name in {row["name"] for row in builtin_network_templates()}:
        raise SystemExit(f"Ошибка: встроенный шаблон нельзя заменить: {name}")
    selected = unique_cidrs(cidrs)
    available = available_network_cidrs()
    missing = [cidr for cidr in selected if cidr not in available]
    if missing:
        raise SystemExit(f"Ошибка: сети нет в каталоге: {', '.join(missing)}")
    rows = [row for row in custom_network_templates() if row["name"] != name]
    template = {"name": name, "description": description, "cidrs": selected, "dns": bool(dns), "builtin": False}
    rows.append(template)
    save_custom_network_templates(rows)
    record_operation("network-template-add", None, "ok", f"template={name} networks={len(selected)}")
    return {"status": "ok", "template": template}


def remove_network_template(name: str) -> Dict[str, Any]:
    name = normalize_template_name(name)
    if name in {row["name"] for row in builtin_network_templates()}:
        raise SystemExit(f"Ошибка: встроенный шаблон нельзя удалить: {name}")
    rows = custom_network_templates()
    new_rows = [row for row in rows if row["name"] != name]
    changed = len(new_rows) != len(rows)
    if changed:
        save_custom_network_templates(new_rows)
    record_operation("network-template-remove", None, "ok", f"template={name} changed={changed}")
    return {"status": "ok", "template": name, "changed": changed}


def get_network_template(name: str) -> Dict[str, Any]:
    name = normalize_template_name(name)
    for row in list_network_templates():
        if row["name"] == name:
            return row
    raise SystemExit(f"Ошибка: шаблон сетей не найден: {name}")


def parse_ccd(path: Path) -> Dict[str, Any]:
    data = {"routes": set(), "iroutes": set(), "dns": False, "domain": False, "vpn_ip": None, "raw": ""}
    if not path.exists():
        return data
    text = path.read_text(encoding="utf-8", errors="replace")
    data["raw"] = text
    for line in text.splitlines():
        line = line.strip()
        m = re.match(r"ifconfig-push\s+(\S+)\s+255\.255\.255\.0", line)
        if m:
            data["vpn_ip"] = m.group(1)
        m = re.match(r'push\s+"route\s+(\S+)\s+(\S+)"', line)
        if m:
            ip, mask = m.group(1), m.group(2)
            try:
                net = ipaddress.ip_network(f"{ip}/{mask}", strict=False)
                data["routes"].add(str(net))
            except ValueError:
                pass
        m = re.match(r"iroute\s+(\S+)\s+(\S+)", line)
        if m:
            ip, mask = m.group(1), m.group(2)
            try:
                net = ipaddress.ip_network(f"{ip}/{mask}", strict=False)
                data["iroutes"].add(str(net))
            except ValueError:
                pass
        if 'dhcp-option DNS' in line:
            data["dns"] = True
        if 'dhcp-option DOMAIN' in line:
            data["domain"] = True
    return data


def infer_client_type_from_ccd(parsed: Dict[str, Any]) -> str:
    if parsed.get("iroutes"):
        return "router_site_to_site"
    vpn_ip = parsed.get("vpn_ip")
    if vpn_ip:
        try:
            addr = ipaddress.ip_address(str(vpn_ip))
            if ip_range_contains(CFG.OPENVPN_ROUTER_POOL_START, CFG.OPENVPN_ROUTER_POOL_END, addr):
                return "router_nat"
        except ValueError:
            pass
    return "user"


def infer_profile(name: str, ccd_path: Path, bat_path: Optional[Path] = None) -> str:
    parsed = parse_ccd(ccd_path)
    routes = parsed["routes"]
    has_dns = bool(parsed["dns"])
    has_bat = bool(bat_path and bat_path.exists())
    d = str(ipaddress.ip_network(CFG.DIRECTUM_IP + "/32", strict=False))
    d17 = str(ipaddress.ip_network(CFG.EXTRA_DIRECTUM_IP + "/32", strict=False))
    dns_net = str(ipaddress.ip_network(CFG.DNS_IP + "/32", strict=False))
    vipnets = set(read_vipnet_nets())
    has_vip = bool(routes.intersection(vipnets))
    has_d = d in routes
    has_d17 = d17 in routes
    has_lan_full = {"192.168.100.0/23", "10.83.1.0/24", "10.10.10.0/23"}.issubset(routes)

    if has_lan_full:
        return "lan_full"
    if has_vip:
        if has_d17:
            return "directum17_vipnet_dns" if has_dns else "directum17_vipnet"
        if has_d:
            # Preserve current backward-compatible profile name.
            return "vipnet" if has_dns else "directum_vipnet"
        return "vipnet_only_dns" if has_dns else "vipnet_only"
    if has_d17:
        return "directum17_dns" if has_dns else ("directum17_hosts" if has_bat else "directum17")
    if has_d:
        return "directum_dns" if has_dns else ("directum_hosts" if has_bat else "directum")
    if dns_net in routes and has_dns:
        return "dns_only"
    return "unknown"

